{
  "name": "monaco-definition-provider",
  "version": "2.0.0",
  "description": "Scope-aware jump-to-definition for Monaco Editor: tree-sitter-backed Python analysis, TypeScript language-service integration, and lazy multi-file workspace navigation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tree-sitter-python.wasm": "./dist/tree-sitter-python.wasm"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:demo": "vite build",
    "build:docs": "typedoc",
    "build:site": "vite build && typedoc",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test"
  },
  "keywords": [
    "monaco-editor",
    "definition-provider",
    "python",
    "typescript",
    "tree-sitter",
    "jump-to-definition",
    "go-to-definition"
  ],
  "author": "jburrow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jburrow/monaco-definition-provider.git"
  },
  "homepage": "https://jburrow.github.io/monaco-definition-provider/",
  "bugs": {
    "url": "https://github.com/jburrow/monaco-definition-provider/issues"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.34.0"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "monaco-editor": "^0.52.0",
    "tree-sitter-python": "0.25.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
